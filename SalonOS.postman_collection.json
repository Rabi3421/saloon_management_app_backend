  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r=pm.response.json();if(r.data&&r.data.token){pm.collectionVariables.set('salon_token',r.data.token);pm.collectionVariables.set('salonId',r.data.salon._id);}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"Rajat Pradhan\",\n  \"email\": \"salon1@salon.com\",\n  \"password\": \"salon1@123\",\n  \"salonName\": \"Rajat's Salon\",\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Main Street\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register-owner",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register-owner"
              ]
            }
          }
        },
        {
          "name": "Login (Owner / Staff / Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r=pm.response.json();if(r.data&&r.data.token){pm.collectionVariables.set('salon_token',r.data.token);if(r.data.salon)pm.collectionVariables.set('salonId',r.data.salon._id);}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@salon.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Register Customer (Salon App)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r=pm.response.json();if(r.data&&r.data.token){pm.collectionVariables.set('salon_token',r.data.token);console.log('salon_token saved');}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Salon-ID",
                "value": "{{salonId}}",
                "description": "The MongoDB _id of the salon. In production this comes from NEXT_PUBLIC_SALON_ID env var."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rajat Customer\",\n  \"email\": \"customer1@test.com\",\n  \"phone\": \"9000000001\",\n  \"password\": \"pass1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register-customer",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register-customer"
              ]
            }
          }
        }
      ]
